    "watch:css": "npx @tailwindcss/cli -i src/main/resources/static/css/input.css -o src/main/resources/static/css/output.css --watch"
  },
  "repository": {
    "type": "git",
    "url": "git@personal:arielZarate/GarageManagementSystem.git"
  },
